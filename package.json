{
  "name": "@pmelab/gtd",
  "version": "3.1.0",
  "private": false,
  "description": "Git-aware CLI that emits the next prompt for an autonomous coding agent based on the current repository state",
  "bin": {
    "gtd": "dist/gtd.bundle.mjs",
    "gtd-loop": "bin/gtd-loop"
  },
  "files": [
    "dist/",
    "bin/",
    "docs/",
    "README.md",
    "LICENSE",
    "schema.json"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pmelab/gtd.git"
  },
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "node dev/run.mjs",
    "build": "tsdown",
    "postbuild": "jiti scripts/generate-schema.ts",
    "watch": "tsdown --watch",
    "test": "npm run format:check && npm run typecheck && npm run lint && npm run test:unit && npm run test:e2e && fallow --summary --quiet",
    "test:unit": "vitest run --project unit",
    "test:watch": "vitest",
    "pretest:e2e": "tsdown --logLevel silent",
    "test:e2e": "vitest run --project e2e",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test:mutation": "stryker run"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern --write"
  },
  "devDependencies": {
    "@effect/language-service": "^0.72.0",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^12.0.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/diff": "^7.0.2",
    "@types/node": "^25.9.3",
    "fallow": "^2.104.0",
    "fast-check": "^4.8.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "quickpickle": "1.11.2",
    "semantic-release": "^25.0.5",
    "tsdown": "^0.22.8",
    "vitest": "^3.2.0",
    "yaml": "^2.8.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@effect/platform": "^0.94.2",
    "@effect/platform-node": "^0.104.1",
    "cosmiconfig": "^9.0.2",
    "diff": "^9.0.0",
    "effect": "^3.19.15",
    "eta": "^4.6.0",
    "prettier": "^3.8.1",
    "vscode-languageserver": "^10.1.0",
    "vscode-languageserver-textdocument": "^1.0.13"
  }
}
