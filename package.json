{
  "name": "gtd",
  "version": "1.4.2",
  "private": true,
  "description": "Agent skill that emits the next prompt for an autonomous coding agent based on the current git state",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pmelab/gtd.git"
  },
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "node dev/run.mjs",
    "build": "tsup",
    "postbuild": "node -e \"require('fs').copyFileSync('dist/gtd.bundle.mjs','scripts/gtd.bundle.mjs')\"",
    "watch": "tsup --watch",
    "test": "npm run format:check && npm run typecheck && npm run lint && vitest run && npm run test:e2e && fallow --summary --quiet",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "pretest:e2e": "tsup --silent && node -e \"require('fs').copyFileSync('dist/gtd.bundle.mjs','scripts/gtd.bundle.mjs')\"",
    "test:e2e": "NODE_OPTIONS=--import=tsx npx cucumber-js --config tests/integration/cucumber.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check . --log-level warn"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.6.0",
    "@cucumber/messages": "^33.0.4",
    "@effect/eslint-plugin": "^0.3.2",
    "@effect/language-service": "^0.72.0",
    "@eslint/js": "^9.39.2",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@types/diff": "^7.0.2",
    "@types/node": "^25.9.3",
    "eslint": "^9.39.2",
    "fallow": "^2.104.0",
    "fast-check": "^4.8.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.8",
    "semantic-release": "^25.0.5",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript-eslint": "^8.54.0",
    "vitest": "^3.2.0",
    "yaml": "^2.8.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@effect/platform": "^0.94.2",
    "@effect/platform-node": "^0.104.1",
    "cosmiconfig": "^9.0.2",
    "diff": "^9.0.0",
    "effect": "^3.19.15",
    "prettier": "^3.8.1"
  }
}
