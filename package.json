{
  "name": "@pmelab/gtd",
  "version": "1.4.3",
  "private": false,
  "description": "Git-aware CLI that emits the next prompt for an autonomous coding agent based on the current repository state",
  "bin": {
    "gtd": "dist/gtd.bundle.mjs"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pmelab/gtd.git"
  },
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "node dev/run.mjs",
    "build": "tsup",
    "watch": "tsup --watch",
    "test": "npm run format:check && npm run typecheck && npm run lint && npm run test:unit && npm run test:e2e && fallow --summary --quiet",
    "test:unit": "vitest run --project unit",
    "test:watch": "vitest",
    "pretest:e2e": "tsup --silent",
    "test:e2e": "vitest run --project e2e",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check . --log-level warn",
    "test:mutation": "stryker run"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write"
  },
  "devDependencies": {
    "@effect/eslint-plugin": "^0.3.2",
    "@effect/language-service": "^0.72.0",
    "@eslint/js": "^9.39.2",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^12.0.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/diff": "^7.0.2",
    "@types/node": "^25.9.3",
    "eslint": "^9.39.2",
    "fallow": "^2.104.0",
    "fast-check": "^4.8.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.8",
    "quickpickle": "1.11.2",
    "semantic-release": "^25.0.5",
    "tsup": "^8.4.0",
    "typescript-eslint": "^8.54.0",
    "vitest": "^3.2.0",
    "yaml": "^2.8.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@effect/platform": "^0.94.2",
    "@effect/platform-node": "^0.104.1",
    "cosmiconfig": "^9.0.2",
    "diff": "^9.0.0",
    "effect": "^3.19.15",
    "prettier": "^3.8.1"
  }
}
