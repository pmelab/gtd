{
  "name": "gtd",
  "version": "1.0.0",
  "private": true,
  "description": "Agent skill that emits the next prompt for an autonomous coding agent based on the current git state",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pmelab/gtd.git"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "scripts": {
    "dev": "node dev/run.mjs",
    "build": "tsup",
    "postbuild": "node -e \"require('fs').copyFileSync('dist/gtd.bundle.mjs','scripts/gtd.bundle.mjs')\"",
    "watch": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest:e2e": "npm run build",
    "test:e2e": "npx cucumber-js --config tests/integration/cucumber.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.6.0",
    "@effect/eslint-plugin": "^0.3.2",
    "@effect/language-service": "^0.72.0",
    "@effect/vitest": "^0.27.0",
    "@eslint/js": "^9.39.2",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@types/node": "^25.9.3",
    "eslint": "^9.39.2",
    "jiti": "^2.6.1",
    "semantic-release": "^25.0.5",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript-eslint": "^8.54.0",
    "vitest": "^3.2.0",
    "yaml": "^2.8.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@effect/platform": "^0.94.2",
    "@effect/platform-node": "^0.104.1",
    "cosmiconfig": "^9.0.2",
    "effect": "^3.19.15",
    "prettier": "^3.8.1"
  }
}
