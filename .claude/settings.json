{
  "permissions": {
    "allow": [
      "Bash(npm run lint)",
      "Bash(npm run typecheck)",
      "Bash(npm run format:check)",
      "Bash(npm run test:unit)",
      "Bash(npm run test:e2e)",
      "Bash(npm test)",
      "Bash(npx tsc --noEmit)",
      "Bash(npx vitest run --project unit *)",
      "Bash(npx vitest run --project e2e *)",
      "Bash(npm run typecheck *)",
      "Bash(npm run lint *)",
      "Bash(npm run test:unit *)",
      "Bash(npx vitest run *)",
      "Bash(npx fallow health *)",
      "Bash(npx fallow --summary *)",
      "Bash(npx fallow --quiet *)",
      "Bash(npx oxlint .)",
      "Bash(npx oxfmt --check .)",
      "mcp__github__actions_list"
    ],
    "deny": ["Bash(npm run test:mutation)", "Bash(npx stryker run)", "Bash(stryker run)"]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx oxfmt --no-error-on-unmatched-pattern --write \"$CLAUDE_TOOL_INPUT_FILE_PATH\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop-permission-scan.sh"
          }
        ]
      }
    ]
  }
}
